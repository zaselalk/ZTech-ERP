PORT=5001
# Required: set a strong secret in production
JWT_SECRET=replace-with-a-strong-secret

# Optional: comma-separated list of allowed origins for CORS
# Example: http://localhost:5173,https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# Database configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=bookshop_db
DB_DIALECT=mysql

# Optional overrides for other environments (used by sequelize config)
DB_NAME_TEST=bookshop_db_test
DB_NAME_PROD=bookshop_db_prod
