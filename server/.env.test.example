# Test Environment Configuration
# This file should be copied to .env.test and configured for your test environment

# Database Configuration (Use a separate test database!)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=ztech_erp_test
DB_DIALECT=mysql

# JWT Secret (Use a different secret for testing)
JWT_SECRET=test_jwt_secret_key_for_testing_only_do_not_use_in_production

# Server Configuration
PORT=5002
NODE_ENV=test

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Email Configuration (Mock or test email service)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=test@example.com
EMAIL_PASS=test_password
EMAIL_FROM=test@example.com

# Cloudinary (Optional - can be mocked in tests)
CLOUDINARY_CLOUD_NAME=test_cloud
CLOUDINARY_API_KEY=test_key
CLOUDINARY_API_SECRET=test_secret
